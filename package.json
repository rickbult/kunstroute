{
  "name": "react-card",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:build": "vite build",
    "dev:preview": "vite preview",
    "dev:backend": "cd server && nodemon server.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cd server && npm start",
    "install-all": "npm install && cd server && npm install"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "express": "^4.19.2",
    "mongoose": "^8.6.1",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "vite": "^4.1.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}